{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XKG Payments",
  "version": "0.1.0",
  "identifier": "ai.xkg.payments",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "XKG Payments",
        "width": 960,
        "height": 720,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; connect-src 'self' http://127.0.0.1:8765 https://api.stripe.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "msi", "nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "XKG Payments — subscription management",
    "longDescription": "Manage XKG subscriptions, view invoices, and update payment methods. Backed by the xkg-payments FastAPI service."
  }
}
