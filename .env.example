# xkg-payments — environment variables
# Copy this file to `.env` and fill in real values before going to production.

# Stripe (test mode by default — use sk_test_... keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_API_VERSION=2025-03-31.basil
STRIPE_TEST_MODE=true

# Service
HOST=127.0.0.1
PORT=8765
DATABASE_URL=sqlite:///./xkg-payments.db
LOG_LEVEL=INFO

# Auth — comma-separated list of bearer tokens allowed to call the REST API
# CHANGE THE DEFAULT BEFORE PRODUCTION.
API_BEARER_TOKENS=devtoken-change-me

# Rate limit (requests per minute per client)
RATE_LIMIT_PER_MINUTE=60
